---
import { site, nav } from "../data/site";
---

<nav class="nav">
  <a class="brand" href="#home" data-tab="home" aria-label={`${site.name} — home`}>
    <span class="mark">RP</span>
    <span>{site.name}</span>
    <span class="sep">/</span>
    <span class="role">{site.role}</span>
  </a>

  <div class="nav-links">
    {nav.map((item) => (
      <a href={item.href} data-tab={item.href.slice(1)}><span class="n">{item.n}</span>{item.label}</a>
    ))}
  </div>

  <a class="nav-status" href="#contact" data-tab="contact" title="Open to remote opportunities">
    <span class="status-dot quiet"></span>
    Available
  </a>

  <button class="menu-btn" aria-label="Open menu">
    Menu
    <span class="bars"><i></i><i></i><i></i></span>
  </button>
</nav>

<div class="mobile-menu">
  {nav.map((item) => (
    <a href={item.href} data-tab={item.href.slice(1)}><span class="n">{item.n}</span>{item.label}</a>
  ))}
  <div class="mm-foot">
    <a href={site.github} target="_blank" rel="noopener">GitHub</a>
    <a href={site.linkedin} target="_blank" rel="noopener">LinkedIn</a>
    <a href={`mailto:${site.email}`}>Email</a>
  </div>
</div>
